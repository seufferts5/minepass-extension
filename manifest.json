{
  "manifest_version": 3,
  "name": "MinePass",
  "version": "1.0.0",
  "description": "Password manager that requires winning Minesweeper to unlock credentials",
  "homepage_url": "https://github.com/yourusername/minesweeper-passwords",
  "author": "Your Name",
  "browser_specific_settings": {
    "gecko": {
      "id": "minepass@seufferts5",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "MinePass"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
